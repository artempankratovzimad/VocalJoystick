<Window x:Class="VocalJoystick.App.Views.DirectionalSampleListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VocalJoystick.App.ViewModels"
        Title="Directional samples"
        Width="560"
        Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowsTransparency="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="DialogBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFDFCFE" Offset="0" />
            <GradientStop Color="#FFE8EDF6" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBackground" Color="White" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3752FF" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E5EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0 0 0 12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="3" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SelectableTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#3F3F43" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="CopyableTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SelectableTextBoxStyle}">
            <Setter Property="Background" Value="#F7F8FB" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource DialogBackground}">
        <Border Background="White" CornerRadius="16" Padding="24" Margin="24" BorderBrush="#D7DDE6" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0 0 0 16">
                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#1F1F23" />
                    <TextBlock Text="{Binding TemplateStatus}" FontSize="13" Foreground="#5D6480" Margin="0 6 0 0" />
                </StackPanel>

                <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderStyle}" Margin="-24 0 -24 16" Background="#F6F7FB">
                    <StackPanel>
                        <TextBlock Text="{Binding AverageStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#1F1F23" />
                        <UniformGrid Columns="2" Margin="0 8 0 0">
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding AverageMfccDisplay, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding AverageSpectralDisplay, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding AverageFormantFirstDisplay, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding AverageFormantSecondDisplay, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding AverageFormantDeltaDisplay, Mode=OneWay}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Samples}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:DirectionalSampleEntryViewModel">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding RecordedAtDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1F1F23" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#5D6480" Text="{Binding DurationDisplay, Mode=OneWay}" Margin="0 4 0 4" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3752FF" Text="{Binding SimilarityDisplay, Mode=OneWay}" Margin="0 0 0 4" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding MfccDisplay, Mode=OneWay}" Margin="0 0 0 4" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding FormantFirstDisplay, Mode=OneWay}" Margin="0 0 0 2" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding FormantSecondDisplay, Mode=OneWay}" Margin="0 0 0 2" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding FormantDeltaDisplay, Mode=OneWay}" Margin="0 0 0 4" />
                                            <TextBox Style="{StaticResource CopyableTextBoxStyle}" FontSize="12" Foreground="#3F3F43" Text="{Binding SpectralDisplay, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Width="120">
                                            <TextBlock Text="{Binding MatchPercentDisplay}" FontSize="15" FontWeight="Bold" Foreground="#3752FF" HorizontalAlignment="Right" />
                                            <Button Content="Delete" Command="{Binding DataContext.DeleteSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0 12 0 0" Padding="8 4" Width="110" HorizontalAlignment="Right" Background="#FFEBF3FF" Foreground="#3752FF" BorderBrush="#A7B5FF" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border DockPanel.Dock="Bottom" BorderBrush="#E2E6EE" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0 16 0 0" Background="#F6F7FB">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#5D6480" VerticalAlignment="Center" />
                        <Button Content="Close" Command="{Binding CloseCommand}" Width="84" Height="32" Margin="12 0 0 0" Background="#3752FF" Foreground="White" BorderBrush="#3752FF" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</Window>
