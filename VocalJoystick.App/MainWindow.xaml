<Window x:Class="VocalJoystick.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vocal Joystick"
        Width="960"
        Height="680"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0C0F1E" Offset="0" />
            <GradientStop Color="#FF171A2B" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1E243A" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <StackPanel Margin="0 0 0 12">
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Microphone" />
                    <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Status:" />
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF8AB4F8" Text="{Binding MicrophoneStatus}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Current Profile" />
                    <TextBlock FontSize="16" Foreground="#FFCFE2FF" Text="{Binding CurrentProfileDisplay}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Configuration Mode" Command="{Binding ConfigurationModeCommand}" Width="160" Height="40" Margin="0 0 12 0" />
                <Button Content="Working Mode" Command="{Binding WorkingModeCommand}" Width="140" Height="40" Margin="0 0 12 0" />
                <Button Content="Stop" Command="{Binding StopCommand}" Width="100" Height="40" Margin="0 0 12 0" />
                <Button Content="Settings" Command="{Binding SettingsCommand}" Width="120" Height="40" />
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Settings" />
                <TextBlock FontSize="16" Foreground="#FFCFE2FF" Text="{Binding SettingsSummary}" />
                <TextBlock FontSize="12" Foreground="#FF7C8CA9" Text="Persistence stored under %AppData%/VocalJoystick" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Microphone Input" />
                <ComboBox ItemsSource="{Binding AvailableMicrophones}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedMicrophoneId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Name"
                          Background="#FF0F1528"
                          Foreground="White"
                          BorderBrush="#FF4260B5"
                          Margin="0 8 0 6" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Selected: {Binding SelectedMicrophoneName}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Capture state: {Binding CaptureState}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Voice Activity" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="VAD state: {Binding VadState}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Last RMS: {Binding LatestRms, StringFormat=F4}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Pitch: {Binding PitchDisplay}" />
                <TextBlock FontSize="12" Foreground="#FF7C8CA9" Text="Pitch confidence: {Binding PitchConfidence, StringFormat=P2}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Threshold" Margin="0 8 0 0" />
                <Slider Minimum="0" Maximum="0.2" SmallChange="0.005" Value="{Binding VadThreshold, Mode=TwoWay}" />
                <TextBlock FontSize="12" Foreground="#FF7C8CA9" Text="Frame Size" Margin="0 10 0 0" />
                <TextBox Text="{Binding FrameSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" Background="#FF0F1528" Foreground="White" BorderBrush="#FF4260B5" />
                <TextBlock FontSize="12" Foreground="#FF7C8CA9" Text="Overlap" Margin="0 10 0 0" />
                <Slider Minimum="0" Maximum="0.95" SmallChange="0.05" Value="{Binding FrameOverlap, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Signal Level" />
                <ProgressBar Minimum="0" Maximum="100" Height="18" Margin="0 8 0 4" Value="{Binding SignalLevelPercent, Mode=OneWay}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="{Binding SignalLevel}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="6" Background="#FF1F2A43" CornerRadius="12" Padding="16" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Configuration Status" />
                <ItemsControl ItemsSource="{Binding ActionStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF0F1528" CornerRadius="6" Padding="8" Margin="0 6 0 0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" Foreground="#FFD6E6FF" Width="160" Text="{Binding DisplayName}" />
                                    <TextBlock FontSize="14" Foreground="#FF8EF0AA" Text="{Binding FriendlyStatus}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="7" Background="#FF1F2A43" CornerRadius="12" Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="Current Command" />
                <TextBlock FontSize="16" Foreground="#FF8AB4F8" Text="{Binding CurrentCommand}" />
                <TextBlock FontSize="14" Foreground="#FFCFE2FF" Text="Mode: {Binding ModeDisplay}" Margin="0 12 0 0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
