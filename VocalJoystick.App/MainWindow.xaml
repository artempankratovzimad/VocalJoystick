<Window x:Class="VocalJoystick.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vocal Joystick"
        Width="960"
        Height="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F8F9FC" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="White" />
        <SolidColorBrush x:Key="PanelStrokeBrush" Color="#E2E6EE" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F1F23" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4C5163" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#737892" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3752FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1F7C54" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B56B00" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#C5302F" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F5F6FA" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D7DDE6" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>
        <Style x:Key="SelectableTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="StatusMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SelectableTextBoxStyle}">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="Warning">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFBFDFF" Offset="0" />
            <GradientStop Color="#FFE9EEF6" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="400" Style="{StaticResource PanelBorderStyle}" Margin="0 0 12 0" VerticalAlignment="Top">
                <StackPanel>
                    <StackPanel Margin="0 0 0 12">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Microphone" />
                        <TextBlock FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Status:" />
                        <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding MicrophoneStatus, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Current Profile" />
                        <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="16" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding CurrentProfileDisplay, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Width="400" Style="{StaticResource PanelBorderStyle}" Margin="0 0 12 0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Settings" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="16" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding SettingsSummary, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="Persistence stored under %AppData%/VocalJoystick" />
                    <StackPanel Margin="0 12 0 0">
                        <TextBlock FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Movement speed" AutomationProperties.HelpText="Adjust how quickly a directional command moves the cursor." />
                        <Slider Minimum="80" Maximum="640" TickFrequency="20" LargeChange="40" SmallChange="10" Value="{Binding MovementSpeed, Mode=TwoWay}" ToolTip="Movement speed in pixels per second" />
                        <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="{Binding MovementSpeed, Mode=OneWay, StringFormat='Speed: {0:F0} px/s'}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Width="400" Style="{StaticResource PanelBorderStyle}" Margin="0 0 12 0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Mode controls" />
                    <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="Configuration Mode" Command="{Binding ConfigurationModeCommand}" Width="160" Height="40" Margin="0 0 12 0"
                                AutomationProperties.HelpText="Enter configuration mode to record vocal templates." />
                        <Button Content="Working Mode" Command="{Binding WorkingModeCommand}" Width="140" Height="40" Margin="0 0 12 0"
                                AutomationProperties.HelpText="Enter working mode to execute mouse commands." />
                        <Button Content="Stop" Command="{Binding StopCommand}" Width="100" Height="40" Margin="0 0 12 0"
                                AutomationProperties.HelpText="Stop any ongoing capture or movement loops." />
                        <Button Content="Settings" Command="{Binding SettingsCommand}" Width="120" Height="40"
                                AutomationProperties.HelpText="Open the settings placeholder." />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Width="400" Style="{StaticResource PanelBorderStyle}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Microphone Input" />
                    <ComboBox ItemsSource="{Binding AvailableMicrophones}"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedMicrophoneId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Name"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              BorderBrush="{StaticResource ControlBorderBrush}"
                              Margin="0 8 0 6" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                             Text="{Binding SelectedMicrophoneName, Mode=OneWay, StringFormat='Selected: {0}'}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                             Text="{Binding CaptureState, Mode=OneWay, StringFormat='Capture state: {0}'}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Width="1600" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Voice Activity" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                         Text="{Binding VadState, Mode=OneWay, StringFormat='VAD state: {0}'}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                         Text="{Binding LatestRms, Mode=OneWay, StringFormat='Last RMS: {0:F4}'}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                         Text="{Binding PitchDisplay, Mode=OneWay, StringFormat='Pitch: {0}'}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                         Text="{Binding PitchConfidence, Mode=OneWay, StringFormat='Pitch confidence: {0:P2}'}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Threshold" Margin="0 8 0 0" />
                <Slider Minimum="0" Maximum="0.2" SmallChange="0.005" Value="{Binding VadThreshold, Mode=TwoWay}" />
                <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="Frame Size" Margin="0 10 0 0" />
                <TextBox Text="{Binding FrameSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource PrimaryTextBrush}" BorderBrush="{StaticResource ControlBorderBrush}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="Overlap" Margin="0 10 0 0" />
                <Slider Minimum="0" Maximum="0.95" SmallChange="0.05" Value="{Binding FrameOverlap, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource PanelBorderStyle}" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Signal Level" />
                <ProgressBar Minimum="0" Maximum="100" Height="18" Margin="0 8 0 4" Value="{Binding SignalLevelPercent, Mode=OneWay}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding SignalLevel, Mode=OneWay}" />
                <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0 6 0 0" Text="Debug buffer" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding BufferDebugInfo, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0 0 0 16">
            <Border.Resources>
                <DataTemplate x:Key="ActionSampleTemplate">
                    <Border Background="{StaticResource InputBackgroundBrush}" BorderBrush="{StaticResource PanelStrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 12 0" MinWidth="220">
                        <StackPanel>
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Action, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding StatusText, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding DurationText, Mode=OneWay}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                                     Text="{Binding SampleCount, Mode=OneWay, StringFormat='Samples: {0}'}" />
                            <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="{Binding FeatureSummary, Mode=OneWay}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0 8 0 0" HorizontalAlignment="Left">
                                <Button Content="Record" Command="{Binding DataContext.StartRecordingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Action}" Width="90" Margin="0 0 6 0" />
                            <Button Content="Stop" Command="{Binding DataContext.StopRecordingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Action}" Width="90" Margin="0 0 6 0" />
                            <Button Content="View" Command="{Binding DataContext.ViewSamplesCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Action}" Width="90" Margin="0 0 6 0" Visibility="{Binding IsDirectional, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="Delete" Command="{Binding DataContext.DeleteRecordingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Action}" Width="90" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
                <Style x:Key="DirectionalItemStyle" TargetType="ContentPresenter">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDirectional}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
                <Style x:Key="ClickItemStyle" TargetType="ContentPresenter">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsClick}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Resources>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Configuration Mode" />
                    <TextBlock FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0 12 0 6" Text="Directional samples" />
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="{Binding TrainingDebugInfo}" TextWrapping="Wrap" Margin="0 0 0 4" />
                <ItemsControl ItemsSource="{Binding ActionSampleStates}" ItemTemplate="{StaticResource ActionSampleTemplate}" ItemContainerStyle="{StaticResource DirectionalItemStyle}" HorizontalAlignment="Left" Margin="0 0 0 12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0 12 0 6" Text="Click samples" />
                <ItemsControl ItemsSource="{Binding ActionSampleStates}" ItemTemplate="{StaticResource ActionSampleTemplate}" ItemContainerStyle="{StaticResource ClickItemStyle}" HorizontalAlignment="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource PanelBorderStyle}" Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Configuration Status" />
                <ItemsControl ItemsSource="{Binding ActionStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource InputBackgroundBrush}" BorderBrush="{StaticResource PanelStrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 6 0 0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Width="160" Text="{Binding DisplayName, Mode=OneWay}" />
                                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SuccessBrush}" Text="{Binding FriendlyStatus, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource PanelBorderStyle}" Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Click Recognition" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding ClickRecognitionStatus, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                             Text="{Binding ClickRecognitionConfidence, Mode=OneWay, StringFormat='Confidence: {0:P0}'}" />
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="Threshold" Margin="0 8 0 0" />
                <Slider Minimum="0" Maximum="1" SmallChange="0.05" Value="{Binding ClickConfidenceThreshold, Mode=TwoWay}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="Cooldown (ms)" Margin="0 10 0 0" />
                <TextBox Text="{Binding ClickCooldownMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource PrimaryTextBrush}" BorderBrush="{StaticResource ControlBorderBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="6" Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Current Command" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="16" Foreground="{StaticResource AccentBrush}" Text="{Binding CurrentCommand, Mode=OneWay}" />
                <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding ModeDisplay, Mode=OneWay}" Margin="0 12 0 0" />
                <TextBox Style="{StaticResource StatusMessageTextBoxStyle}" FontSize="14" Margin="0 4 0 0" TextWrapping="Wrap" Text="{Binding StatusMessage, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="7" Style="{StaticResource PanelBorderStyle}" AutomationProperties.HelpText="Direction recognition diagnostics panel">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Direction diagnostics" />
                <UniformGrid Columns="2" Margin="0 12 0 0">
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Direction:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionCandidateDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Status:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionStatusMessage, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Confidence:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionConfidenceDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Hold:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionHoldDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Voice:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionVoiceDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Pitch:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionPitchDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="RMS:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionRmsDisplay, Mode=OneWay}" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Text="Templates:" />
                    <TextBox Style="{StaticResource SelectableTextBoxStyle}" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding DirectionTemplateStatus, Mode=OneWay}" />
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
